should match snapshot when create=true and data is provided:
  1: |
    apiVersion: v1
    data:
      config.yaml: |-
        version: v1
        mig-configs:
          all-disabled:
            - devices: all
              mig-enabled: false
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/instance: gpu-operator
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: gpu-operator
        app.kubernetes.io/version: main-latest
        helm.sh/chart: gpu-operator-v1.0.0-devel
      name: custom-mig-parted
      namespace: gpu-operator
